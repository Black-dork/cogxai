# ──────────────────────────────────────────────
# COGXAI — Environment Configuration
# ──────────────────────────────────────────────

# ── MODE SELECTION ─────────────────────────────
# Local mode: set COGXAI_LOCAL=true (no other keys needed)
# Hosted mode: set CORTEX_API_KEY (connects to cogxai.org API)
# Self-hosted mode: set SUPABASE_URL + SUPABASE_SERVICE_KEY

COGXAI_LOCAL=false
CORTEX_API_KEY=
CORTEX_HOST_URL=https://cogxai.org

# ── SUPABASE (required for self-hosted mode) ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── EMBEDDING (required for cloud/self-hosted) ─
# Options: openai, voyage, venice
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024

# ── LLM INFERENCE (for dream cycles, reflection) ─
# Primary: anthropic, venice, or auto
INFERENCE_PRIMARY=auto
INFERENCE_FALLBACK=anthropic
ANTHROPIC_API_KEY=
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b

# ── SERVER ─────────────────────────────────────
PORT=3000
BASE_URL=https://your-app.railway.app

# ── BASE (optional — on-chain verification) ──
BASE_RPC_URL=https://api.mainnet.base.com
BOT_WALLET_PRIVATE_KEY=
COGXAI_TOKEN_CONTRACT=

# ── X / TWITTER (optional — social features) ──
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BOT_USER_ID=

# ── TELEGRAM (optional) ───────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── TUNING ─────────────────────────────────────
MENTION_POLL_INTERVAL_MS=30000
PRICE_POLL_INTERVAL_MS=60000
MOOD_TWEET_INTERVAL_MS=7200000
AGENT_RATE_LIMIT=10

# ── FEATURE FLAGS ──────────────────────────────
SITE_ONLY=false
CAMPAIGN_ENABLED=false
TELEGRAM_ENABLED=false
SHOW_TX_LINKS_IN_TWEETS=false
